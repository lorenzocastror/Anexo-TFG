# =============================================================================
# --- PARÁMETROS EXPERIMENTALES ---
# =============================================================================
PIXEL_SIZE = 0.05        # Resolución espacial (micras/píxel)
FRAME_INTERVAL = 3.906   # Resolución temporal (segundos/frame)
MIN_FRAMES = 10          # Umbral de persistencia temporal mínima (número de frames)

def calcular_metricas_tracks(df, pixel_size=PIXEL_SIZE, frame_interval=FRAME_INTERVAL):
    """
    Cálculo de métricas cinemáticas (velocidad, desplazamiento y persistencia) por trayectoria.
    """
    metrics = []
    
    for track_id, group in df.groupby('Track_ID'):
        group = group.sort_values('Frame')
        
        # Exclusión de seguridad para trayectorias con un único punto de registro temporal
        if len(group) < 2:
            continue
            
        # Extracción y conversión de coordenadas a unidades físicas
        x = group['Pos_X'].values * pixel_size
        y = group['Pos_Y'].values * pixel_size
        t = group['Frame'].values * frame_interval
        
        # Cálculo de desplazamientos vectoriales y diferencias temporales
        dx = np.diff(x)
        dy = np.diff(y)
        dt = np.diff(t)
        
        # Prevención de divisiones por cero ante posibles duplicidades temporales
        dt[dt == 0] = np.nan
        
        step_distances = np.sqrt(dx**2 + dy**2)
        velocities = step_distances / dt
        
        # Consolidación de métricas de trayectoria
        total_dist = np.sum(step_distances)
        net_disp = np.sqrt((x[-1]-x[0])**2 + (y[-1]-y[0])**2)
        
        metrics.append({
            'Track_ID': track_id,
            'Duration_s': t[-1] - t[0],
            'N_Frames': len(group),
            'Total_Distance_um': total_dist,
            'Net_Displacement_um': net_disp,
            'Mean_Velocity_um_s': np.nanmean(velocities),
            'Max_Velocity_um_s': np.nanmax(velocities),
            'Std_Velocity': np.nanstd(velocities),
            # Índice de direccionalidad (1 = rectilíneo, 0 = aleatorio/circular)
            'Directionality': net_disp / total_dist if total_dist > 0 else 0,
            'Mean_Area_um2': group['Area_pixels'].mean() * (pixel_size**2)
        })
        
    return pd.DataFrame(metrics)

def calcular_metricas_radiales(df_traj, df_cells, pixel_size=PIXEL_SIZE, frame_interval=FRAME_INTERVAL):
    """
    Evaluación de la dinámica espacial relativa al centroide celular.
    Integra los datos de trayectoria organular con las coordenadas del centro de masa celular.
    """
    # Fusión de datos espaciales (trayectorias y centroides celulares)
    df_merged = pd.merge(
        df_traj, 
        df_cells[['Frame', 'Centro_Masa_Celula_X', 'Centro_Masa_Celula_Y']], 
        on='Frame', 
        how='inner'
    )
    
    metrics = []
    
    for track_id, group in df_merged.groupby('Track_ID'):
        group = group.sort_values('Frame')
        if len(group) < 2:
            continue
            
        mito_pos = group[['Pos_X', 'Pos_Y']].values * pixel_size
        cell_center = group[['Centro_Masa_Celula_X', 'Centro_Masa_Celula_Y']].values * pixel_size
        
        # Cuantificación de la distancia euclídea al centroide celular en función del tiempo
        dist_to_center = np.linalg.norm(mito_pos - cell_center, axis=1)
        
        # Diferencial de distancia (valores positivos indican desplazamiento centrífugo)
        radial_changes = np.diff(dist_to_center)
        dt = np.diff(group['Frame'].values * frame_interval)
        
        dt[dt == 0] = np.nan 
        
        radial_velocities = radial_changes / dt
        
        # Radial Bias: Fracción de desplazamientos que incrementan la distancia al centroide celular.
        radial_bias = np.mean(radial_changes > 0)
        
        metrics.append({
            'Track_ID': track_id,
            'Initial_Dist_Center_um': dist_to_center[0],
            'Final_Dist_Center_um': dist_to_center[-1],
            'Net_Radial_Change_um': dist_to_center[-1] - dist_to_center[0],
            'Mean_Radial_Velocity_um_s': np.mean(radial_velocities),
            'Radial_Bias': radial_bias
        })
        
    return pd.DataFrame(metrics)

def calcular_clustering(df, pixel_size=PIXEL_SIZE):
    """
    Análisis de la topología espacial poblacional (distancia al vecino más cercano) por frame.
    """
    metrics = []
    
    for t, group in df.groupby('Frame'):
        positions = group[['Pos_X', 'Pos_Y']].values * pixel_size
        
        # Requisito mínimo de elementos para la validez del cálculo topológico
        if len(positions) < 3: 
            continue
            
        # Generación de la matriz de distancias espaciales emparejadas
        dist_matrix = squareform(pdist(positions))
        np.fill_diagonal(dist_matrix, np.inf)
        
        # Extracción de la distancia al vecino más cercano (Nearest Neighbor)
        nn_distances = np.min(dist_matrix, axis=1)
        
        metrics.append({
            'Frame': t,
            'N_Mitochondria': len(positions),
            'Mean_NN_Distance_um': np.mean(nn_distances),
            'Std_NN_Distance_um': np.std(nn_distances)
        })
        
    return pd.DataFrame(metrics)

def calcular_msd_ensemble(df, pixel_size=PIXEL_SIZE, frame_interval=FRAME_INTERVAL, max_lag=8):
    """
    Cálculo del Desplazamiento Cuadrático Medio (MSD) promediado para el conjunto poblacional (Ensemble).
    """
    msd_dict = {lag: [] for lag in range(1, max_lag + 1)}
    
    for track_id, group in df.groupby('Track_ID'):
        group = group.sort_values('Frame')
        if len(group) <= 1: continue

        x = group['Pos_X'].values * pixel_size
        y = group['Pos_Y'].values * pixel_size
        
        # Cuantificación de desplazamientos iterando sobre los intervalos temporales (lags)
        max_lag_track = min(max_lag, len(x)-1)
        for lag in range(1, max_lag_track + 1):
            sq_disp = (x[lag:] - x[:-lag])**2 + (y[lag:] - y[:-lag])**2
            msd_dict[lag].extend(sq_disp)
            
    # Cálculo del promedio poblacional por intervalo de retardo
    lags_sec = []
    msd_vals = []
    for lag in range(1, max_lag + 1):
        if len(msd_dict[lag]) > 0:
            lags_sec.append(lag * frame_interval)
            msd_vals.append(np.mean(msd_dict[lag]))
            
    return np.array(lags_sec), np.array(msd_vals)

