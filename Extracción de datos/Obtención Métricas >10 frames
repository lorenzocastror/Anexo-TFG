def procesar_metricas_totales_filtrado():
    # Definición de la ruta del archivo maestro de entrada
    ruta_archivo = r"Videos_Mitocondrias\Resultados Analisis_TFG\Master_Analisis_Mitocondrias_Filtrado.xlsx"
    
    # Definición de la ruta de exportación de resultados
    ruta_salida = r"Videos_Mitocondrias/Resultados Analisis_TFG/Metricas_Detalladas_Mitocondrias_10_Frames_TFG.xlsx"
    
    print("Cargando archivo maestro...")
    if not os.path.exists(ruta_archivo):
        print(f"Error: Archivo no localizado en la ruta {ruta_archivo}")
        return
    
    df_traj_totales = pd.read_excel(ruta_archivo, sheet_name="Trayectorias Totales")
    df_celulas_totales = pd.read_excel(ruta_archivo, sheet_name="Datos Células Totales")

    # =========================================================
    # 🛡️ CONTROL DE CALIDAD Y DEPURACIÓN ESTRUCTURAL DE DATOS
    # =========================================================
    
    # --- CONTROL 1: Eliminación de registros nulos y estandarización de metadatos ---
    df_traj_totales = df_traj_totales.dropna(subset=['Nombre del vídeo'])
    df_celulas_totales = df_celulas_totales.dropna(subset=['Nombre del vídeo'])
    
    df_traj_totales['Nombre del vídeo'] = df_traj_totales['Nombre del vídeo'].astype(str)
    df_celulas_totales['Nombre del vídeo'] = df_celulas_totales['Nombre del vídeo'].astype(str)
    
    # --- CONTROL 2: Prevención de duplicidad temporal en trayectorias ---
    # Supresión de registros que presenten solapamiento idéntico en vídeo, 
    # identificador de trayectoria (Track_ID) y frame, conservando únicamente la primera observación.
    df_traj_totales = df_traj_totales.drop_duplicates(subset=['Nombre del vídeo', 'Track_ID', 'Frame'], keep='first')
    
    # Filtrado análogo para los centroides celulares, garantizando una única coordenada referencial por frame y vídeo.
    df_celulas_totales = df_celulas_totales.drop_duplicates(subset=['Nombre del vídeo', 'Frame'], keep='first')
    
    # =========================================================

    # Inicialización de estructuras de almacenamiento de resultados
    resultados_tracks = []
    resultados_msd = []
    resultados_clustering = []
    
    # Extracción de identificadores únicos de experimentación
    videos_unicos = df_traj_totales['Nombre del vídeo'].unique()

    print(f"Analizando {len(videos_unicos)} registros poblacionales (Umbral de persistencia: > {MIN_FRAMES} frames)...")
    
    for video in videos_unicos:
        # Extracción de la etiqueta del grupo experimental aislando el sufijo direccional
        grupo = video.rsplit('_', 1)[0]
        
        # Aislamiento de datos correspondientes al identificador actual
        df_t = df_traj_totales[df_traj_totales['Nombre del vídeo'] == video].copy()
        df_c = df_celulas_totales[df_celulas_totales['Nombre del vídeo'] == video].copy()
        
        # --- CONTROL 3: Filtrado de persistencia temporal mínima ---
        track_counts = df_t['Track_ID'].value_counts()
        valid_tracks = track_counts[track_counts > MIN_FRAMES].index
        
        n_antes = len(df_t)
        df_t = df_t[df_t['Track_ID'].isin(valid_tracks)].copy()
        n_despues = len(df_t)
        
        print(f"-> Procesando: {video} | Trayectorias válidas: {len(valid_tracks)} (Depuración de registros: {n_antes} -> {n_despues})")
        
        if df_t.empty:
            print(f"   Advertencia: Ninguna trayectoria supera el umbral de persistencia mínima ({MIN_FRAMES} frames) en este registro.")
            continue
        
        # 1. Extracción de métricas cinemáticas elementales
        m_tracks = calcular_metricas_tracks(df_t)
        
        # 2. Extracción de métricas radiales (condicionado a la disponibilidad de datos de segmentación celular)
        if not df_c.empty:
            m_radiales = calcular_metricas_radiales(df_t, df_c)
            # Integración de parámetros radiales al conjunto de datos principal
            if not m_radiales.empty:
                m_tracks = pd.merge(m_tracks, m_radiales, on='Track_ID', how='left')
        
        # Inserción de metadatos descriptivos
        m_tracks.insert(0, 'Nombre del vídeo', video)
        m_tracks.insert(1, 'Grupo', grupo)
        resultados_tracks.append(m_tracks)
        
        # 3. Cuantificación de la agrupación espacial (Clustering topológico de trayectorias persistentes)
        m_cluster = calcular_clustering(df_t)
        m_cluster.insert(0, 'Nombre del vídeo', video)
        m_cluster.insert(1, 'Grupo', grupo)
        resultados_clustering.append(m_cluster)
        
        # 4. Cálculo del MSD (requiere almacenamiento independiente por su dimensionalidad temporal intrínseca)
        lags, msd = calcular_msd_ensemble(df_t)
        if len(lags) > 0:
            df_msd = pd.DataFrame({'Lag_s': lags, 'MSD_um2': msd})
            df_msd.insert(0, 'Nombre del vídeo', video)
            df_msd.insert(1, 'Grupo', grupo)
            resultados_msd.append(df_msd)

    # =============================================================================
    # --- EXPORTACIÓN DE RESULTADOS ---
    # =============================================================================
    print(f"\nGuardando resultados en: {ruta_salida}")
    
    with pd.ExcelWriter(ruta_salida, engine='openpyxl') as writer:
        if resultados_tracks:
            pd.concat(resultados_tracks).to_excel(writer, sheet_name="Métricas por Track", index=False)
        if resultados_clustering:
            pd.concat(resultados_clustering).to_excel(writer, sheet_name="Clustering Temporal", index=False)
        if resultados_msd:
            pd.concat(resultados_msd).to_excel(writer, sheet_name="Curvas MSD", index=False)
            
    print("¡Proceso finalizado con éxito!")

if __name__ == "__main__":
    procesar_metricas_totales_filtrado()
